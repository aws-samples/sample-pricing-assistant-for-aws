{
  "name": "aws-pricing-assistant-backend",
  "version": "1.0.0",
  "description": "Backend API for AWS Pricing Assistant Chatbot",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.993.0",
    "@aws-sdk/client-bedrock-runtime": "^3.993.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.993.0",
    "@aws-sdk/client-dynamodb": "^3.993.0",
    "@aws-sdk/client-pricing": "^3.993.0",
    "@aws-sdk/client-s3": "^3.993.0",
    "@aws-sdk/client-savingsplans": "^3.993.0",
    "@aws-sdk/lib-dynamodb": "^3.993.0",
    "@aws-sdk/s3-request-presigner": "^3.864.0",
    "@cdktf/hcl2json": "^0.21.0",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "axios": "^1.11.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.0",
    "helmet": "^7.1.0",
    "jose": "^5.9.0",
    "js-yaml": "^4.1.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "uuid": "^14.0.0",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.9.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.1.0",
    "typescript": "^5.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "minimatch": ">=10.0.0"
  }
}
